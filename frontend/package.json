{
  "name": "urban-clash-team",
  "description": "Backend e Frontend para o jogo Urban Clash Team",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "check:db": "node check_db.js",
    "dev": "vite --port 3000",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "vite",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run type-check",
    "guard": "node config/scripts/ai-guard.js",
    "full-check": "npm run validate && npm run guard",
    "predev": "npm run validate",
    "prebuild": "npm run validate",
    "services:start": "powershell -ExecutionPolicy Bypass -File start-services.ps1",
    "services:docker": "docker-compose up -d",
    "services:docker-stop": "docker-compose down",
    "ai": "node config/scripts/configscriptsai-run.js",
    "dev:token": "node dev_email_helper.js new",
    "dev:token-list": "node dev_email_helper.js list",
    "dev:token-clean": "node dev_email_helper.js clean",
    "dev:token-test": "node dev_email_helper.js test"
  },
  "dependencies": {
    "@fontsource/exo-2": "^5.0.3",
    "@fontsource/orbitron": "^5.0.3",
    "@heroicons/react": "^2.2.0",
    "@sendgrid/mail": "^8.1.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "axios": "^1.15.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "dotenv": "^16.3.1",
    "framer-motion": "^11.2.10",
    "jsdom": "^24.1.0",
    "lucide-react": "^1.7.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.2.1",
    "react-router-dom": "^6.23.1",
    "react-tooltip": "^5.26.3",
    "swr": "^2.2.5",
    "typescript": "^5.4.5",
    "urbanclash-monorepo": "file:..",
    "uuid": "^9.0.1",
    "vite": "^6.4.2",
    "vite-plugin-svgr": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "husky": "^9.0.11",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "wrangler": "^4.90.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "tar": "^7.5.12",
    "follow-redirects": "1.16.0"
  }
}
