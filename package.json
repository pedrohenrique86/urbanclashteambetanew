{
  "name": "urban-clash-team",
  "description": "Backend e Frontend para o jogo Urban Clash Team",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "check:db": "node check_db.js",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "vite",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run type-check",
    "guard": "node config/scripts/ai-guard.js",
    "full-check": "npm run validate && npm run guard",
    "predev": "npm run validate",
    "prebuild": "npm run validate",
    "backend:dev": "cd backend && npm run dev",
    "dev:start": "start-dev.bat",
    "services:start": "powershell -ExecutionPolicy Bypass -File start-services.ps1",
    "services:start-simple": "start-services.bat",
    "services:docker": "docker-compose up -d",
    "services:docker-stop": "docker-compose down",
    "ai": "node config/scripts/configscriptsai-run.js",
    "dev:token": "node dev_email_helper.js new",
    "dev:token-list": "node dev_email_helper.js list",
    "dev:token-clean": "node dev_email_helper.js clean",
    "dev:token-test": "node dev_email_helper.js test"
  },
  "dependencies": {
    "@fontsource/exo-2": "^5.0.3",
    "@fontsource/orbitron": "^5.0.3",
    "@sendgrid/mail": "^8.1.3",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.3.1",
    "framer-motion": "^10.16.4",
    "jsdom": "^26.1.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.6.2",
    "react-tooltip": "^5.29.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swr": "^2.2.0",
    "typescript": "^5.0.2",
    "uuid": "^11.1.0",
    "vite": "^6.3.5",
    "vite-plugin-svgr": "^4.5.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "husky": "^9.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.3.3"
  }
}
