{
  "name": "urbanclash-backend",
  "version": "1.0.0",
  "description": "Backend API para UrbanClash",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "predev": "docker-compose -f ../docker-compose.yml up -d redis",
    "dev": "wait-on tcp:6379 && nodemon server.js",
    "test": "jest",
    "migrate": "node-pg-migrate",
    "migrate:create": "npm run migrate -- create",
    "migrate:up": "npm run migrate -- up",
    "migrate:down": "npm run migrate -- down"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.11.3",
    "redis": "^5.11.0",
    "resend": "^3.5.0",
    "socket.io": "^4.8.3",
    "urbanclash-monorepo": "file:..",
    "uuid": "^9.0.1",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "urbanclash",
    "api",
    "express",
    "postgresql"
  ],
  "author": "UrbanClash Team",
  "license": "MIT"
}
