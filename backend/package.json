{
  "name": "urbanclash-backend",
  "version": "1.0.0",
  "description": "Backend API para UrbanClash",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "predev": "docker-compose -f ../docker-compose.yml up -d redis",
    "dev": "wait-on tcp:6379 && nodemon server.js",
    "test": "jest",

    "migrate": "node-pg-migrate",
    "migrate:create": "npm run migrate -- create",
    "migrate:up": "npm run migrate -- up",
    "migrate:down": "npm run migrate -- down",

    "migrate:up:dev": "node scripts/run-migrate.js dev up",
    "migrate:down:dev": "node scripts/run-migrate.js dev down",
    "migrate:up:prod": "node scripts/run-migrate.js prod up",
    "migrate:down:prod": "node scripts/run-migrate.js prod down",

    "migrate:up:all": "npm run migrate:up:dev && npm run migrate:up:prod",
    "migrate:down:all": "npm run migrate:down:prod && npm run migrate:down:dev"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "node-pg-migrate": "^7.5.0",
    "wait-on": "^7.2.0"
  }
}