{
  "name": "urbanclash-backend",
  "version": "1.0.0",
  "description": "Backend API para UrbanClash",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "setup:sqlite": "node ../scripts/setup_sqlite.js",
    "seed:sqlite": "node ../scripts/seed_sqlite.js",
    "dev:local": "cross-env NODE_ENV=development PORT=3002 nodemon server.js",
    "dev:all": "docker-compose -f ../docker-compose.yml up -d redis && npm run dev:local"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "googleapis": "^134.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "redis": "^4.6.13",
    "resend": "^3.2.0",
    "urbanclash-monorepo": "file:..",
    "wait-on": "^7.2.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "overrides": {
    "glob": "11.1.0"
  }
}
