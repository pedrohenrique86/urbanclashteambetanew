# URBAN CLASH - TEMPLATE DE CONFIGURAÇÃO (.env.example)
# Copie este arquivo para .env e preencha os valores reais.

# --- BANCO DE DADOS (libSQL) ---
LIBSQL_URL=

# --- SEGURANÇA ---
# Chave de 64 caracteres recomendada
JWT_SECRET=

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- EMAIL (RESEND) ---
RESEND_API_KEY=
FROM_EMAIL=no-reply@urbanclash.com

# --- URLs ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3002

# --- REDIS ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- AMBIENTE ---
PORT=3001
NODE_ENV=development
